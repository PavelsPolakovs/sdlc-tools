{
  "name": "sdlc-ship-changes",
  "version": "0.1.0",
  "description": "MCP server exposing a curated tool surface for the ship-changes SDLC pipeline",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "sdlc-ship-changes": "./dist/server.js"
  },
